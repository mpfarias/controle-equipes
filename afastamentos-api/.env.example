# Copie para `.env` na pasta afastamentos-api (o `.env` real está no .gitignore deste pacote).

# Banco principal — Prisma, login, usuários, Órion Qualidade (registros, policiais).
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/afastamentos_db"

# Opcional: banco remoto integra_ssp (Órion Qualidade — consultas de chamadas). Não usado para autenticação.
#
# SQL Server (produção — conforme DBeaver):
INTEGRA_SSP_MSSQL_HOST=10.91.41.154
INTEGRA_SSP_MSSQL_PORT=1433
INTEGRA_SSP_MSSQL_DATABASE=integra_ssp
INTEGRA_SSP_MSSQL_USER=user_farias
INTEGRA_SSP_MSSQL_PASSWORD=SUA_SENHA
INTEGRA_SSP_MSSQL_TRUST_SERVER_CERTIFICATE=true
# Obrigatório se HOST for IP: nome TLS/SNI do certificado do SQL Server (ex.: LISTEN-SQL-PROD)
INTEGRA_SSP_MSSQL_TLS_SERVER_NAME=LISTEN-SQL-PROD
# INTEGRA_SSP_MSSQL_ENCRYPT=false  # rede interna, se TLS continuar falhando
#
# Download de gravações: usa o caminho EXATO de record_file (ex.: /var/spool/asterisk/monitor/2026/02/11/arquivo.WAV).
# Modo padrão (fullpath-query): BASE?file=<caminho_completo_codificado>
# INTEGRA_SSP_RECORD_FILE_BASE_URL=https://servidor-hefesto/caminho/download
# INTEGRA_SSP_RECORD_FILE_URL_MODE=fullpath-query
# Alternativa relativa: INTEGRA_SSP_RECORD_FILE_URL_MODE=relative
# INTEGRA_SSP_RECORD_FILE_PATH_PREFIX=/var/spool/asterisk/monitor
#
# PostgreSQL (legado/dev alternativo):
# INTEGRA_SSP_DATABASE_URL=postgresql://USUARIO:SENHA_ENCODADA@HOST:5432/integra_ssp

# Se o Postgres remoto exigir TLS com certificado não confiável (mesma regra do pool principal em pg-pool-config):
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# ou: DATABASE_PG_TLS_INSECURE=true

# CORS / links na API
# FRONTEND_URL=http://localhost:5173
# API_URL=http://localhost:3002

# Obrigatório quando NODE_ENV=production (gerado automaticamente por scripts/windows se ausente)
# JWT_SECRET=

# Órion Mulher — planilha padrão para importação Excel (opcional)
# MULHER_EXCEL_PATH=../sisCopomMulher/FormularioViolenciaDomestica (respostas).xlsx
# Banco legado sisCopomMulher (opcional; padrão = DATABASE_URL) para npm run migrar:sis-copom-mulher
# MULHER_LEGACY_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/sis_copom_mulher
