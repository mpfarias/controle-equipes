generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Policial {
  id                         Int                        @id @default(autoincrement())
  nome                       String
  matricula                  String                     @unique
  cpf                        String?
  telefone                   String?
  dataNascimento             DateTime?
  email                      String?
  matriculaComissionadoGdf   String?
  dataPosse                  DateTime?
  equipe                     String?
  statusId                   Int
  status                     StatusPolicial             @relation(fields: [statusId], references: [id])
  funcaoId                   Int?
  funcao                     Funcao?                    @relation(fields: [funcaoId], references: [id])
  restricaoMedicaId          Int?
  restricaoMedica            RestricaoMedica?           @relation(fields: [restricaoMedicaId], references: [id])
  restricaoMedicaObservacao  String?
  restricoesMedicasHistorico RestricaoMedicaHistorico[]
  fotoUrl                    String?
  ferias                     FeriasPolicial[]
  afastamentos               Afastamento[]
  trocasServicoComoA         TrocaServico[]             @relation("TrocaServicoPolicialA")
  trocasServicoComoB         TrocaServico[]             @relation("TrocaServicoPolicialB")
  createdById                Int?
  createdByName              String?
  updatedById                Int?
  updatedByName              String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  dataDesativacaoAPartirDe   DateTime?
  observacoesDesativacao     String?
  desativadoPorId            Int?
  desativadoPorNome          String?
  desativadoEm               DateTime?
}

model StatusPolicial {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  descricao String?
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model FeriasPolicial {
  id                 Int       @id @default(autoincrement())
  policialId         Int
  policial           Policial  @relation(fields: [policialId], references: [id], onDelete: Cascade)
  ano                Int
  dataInicio         DateTime
  dataFim            DateTime
  /** Exercícios anteriores ao ano civil: permite cadastrar só o ano; datas são placeholder (jan.) até definir o mês. */
  semMesDefinido     Boolean   @default(false)
  confirmada         Boolean   @default(false)
  reprogramada       Boolean   @default(false)
  dataInicioOriginal DateTime?
  dataFimOriginal    DateTime?
  createdById        Int?
  createdByName      String?
  updatedById        Int?
  updatedByName      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([policialId, ano])
}

model MotivoAfastamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  descricao    String?
  afastamentos Afastamento[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Afastamento {
  id            Int               @id @default(autoincrement())
  policialId    Int
  policial      Policial          @relation(fields: [policialId], references: [id], onDelete: Cascade)
  motivoId      Int
  motivo        MotivoAfastamento @relation(fields: [motivoId], references: [id])
  seiNumero     String
  descricao     String?
  /**
   * Ano da cota de férias (exercício) quando o gozo é em outro ano (ex.: direito de 2024, gozo em 2026).
   * Nulo = considerar o ano civil da data de início (comportamento legado).
   */
  anoExercicioFerias Int?
  dataInicio    DateTime
  dataFim       DateTime?
  status        AfastamentoStatus @default(ATIVO)
  /** Preenchido ao desativar manualmente ou pelo encerramento automático (fim do período). */
  desativadoPorId   Int?
  desativadoPorNome String?
  desativadoEm      DateTime?
  createdById   Int?
  createdByName String?
  updatedById   Int?
  updatedByName String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model UsuarioNivel {
  id         Int                     @id @default(autoincrement())
  nome       String                  @unique
  descricao  String?
  ativo      Boolean                 @default(true)
  /** Quando true, usuários deste nível podem acessar o app Órion Suporte (gestão de chamados). */
  acessoOrionSuporte Boolean         @default(false)
  usuarios   Usuario[]
  permissoes UsuarioNivelPermissao[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
}

model Funcao {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  descricao String?
  ativo     Boolean    @default(true)
  usuarios  Usuario[]
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Usuario {
  id                    Int           @id @default(autoincrement())
  nome                  String
  matricula             String        @unique
  senhaHash             String
  perguntaSeguranca     String?
  respostaSegurancaHash String?
  equipe                String?
  status                UsuarioStatus @default(ATIVO)
  isAdmin               Boolean       @default(false)
  nivelId               Int?
  nivel                 UsuarioNivel? @relation(fields: [nivelId], references: [id])
  nivelRemovidoEm       DateTime?     // Quando o nível foi excluído e o usuário ficou sem nível
  funcaoId              Int?
  funcao                Funcao?       @relation(fields: [funcaoId], references: [id])
  fotoUrl               String?
  /**
   * Órion Suporte: null = herdar do nível; true = garantir acesso; false = bloquear mesmo que o nível conceda.
   */
  acessoOrionSuporte    Boolean?
  /** SPAs do ecossistema: SAD, OPERACOES, ORION_QUALIDADE, ORION_JURIDICO, ORION_PATRIMONIO, ORION_MULHER, … (ver `SISTEMAS_EXTERNOS_IDS` na API). */
  sistemasPermitidos    String[]      @default([])
  createdById           Int?
  createdByName         String?
  updatedById           Int?
  updatedByName         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  errorReports          ErrorReport[]
  /** Registros criados no módulo Órion Qualidade. */
  qualidadeRegistrosCriados QualidadeRegistro[] @relation("QualidadeRegistroAutor")
  /** Bens cadastrados no módulo Órion Patrimônio. */
  patrimonioBensCriados PatrimonioBem[] @relation("PatrimonioBemAutor")
}

enum AfastamentoStatus {
  ATIVO
  /** Fim automático após o término do período (data fim). */
  ENCERRADO
  /** Desativação manual no sistema; mantém auditoria em desativadoPor* / desativadoEm. */
  DESATIVADO
}

enum UsuarioStatus {
  ATIVO
  DESATIVADO
}

/** Ciclo de vida de um registro de gestão da qualidade (Órion Qualidade). */
enum QualidadeRegistroStatus {
  ABERTO
  EM_TRATAMENTO
  ENCERRADO
}

/**
 * Registro de oportunidade de melhoria / não conformidade leve / acompanhamento de qualidade.
 * Acesso à API restrito a quem tem `ORION_QUALIDADE` em sistemasPermitidos (cadastro no SAD).
 */
model QualidadeRegistro {
  id                Int                     @id @default(autoincrement())
  titulo            String
  descricao         String?                 @db.Text
  status            QualidadeRegistroStatus @default(ABERTO)
  criadoPorId       Int
  criadoPor         Usuario                 @relation("QualidadeRegistroAutor", fields: [criadoPorId], references: [id])
  criadoPorNome     String
  atualizadoPorId   Int?
  atualizadoPorNome String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([criadoPorId])
  @@index([status])
  @@map("qualidade_registro")
}

/** Situação do bem no acervo do COPOM (Órion Patrimônio). */
enum PatrimonioBemSituacao {
  EM_USO
  GUARDADO
  MANUTENCAO
  EMPRESTADO
  BAIXADO
}

/**
 * Bem patrimonial tombado. Acesso à API restrito a quem tem `ORION_PATRIMONIO` em sistemasPermitidos.
 */
model PatrimonioBem {
  id                Int                   @id @default(autoincrement())
  tombamento        String                @unique @db.VarChar(64)
  descricao         String                @db.VarChar(500)
  categoria         String?               @db.VarChar(120)
  marca             String?               @db.VarChar(120)
  modelo            String?               @db.VarChar(120)
  numeroSerie       String?               @db.VarChar(120)
  localizacaoSetor  String?               @db.VarChar(200)
  situacao          PatrimonioBemSituacao @default(EM_USO)
  observacoes       String?               @db.Text
  dataAquisicao     DateTime?             @db.Date
  valorAquisicao    Decimal?              @db.Decimal(14, 2)
  criadoPorId       Int
  criadoPor         Usuario               @relation("PatrimonioBemAutor", fields: [criadoPorId], references: [id])
  criadoPorNome     String                @db.VarChar(200)
  atualizadoPorId   Int?
  atualizadoPorNome String?               @db.VarChar(200)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([situacao])
  @@index([criadoPorId])
  @@index([tombamento])
  @@map("patrimonio_bem")
}

enum PermissaoAcao {
  VISUALIZAR
  EDITAR
  DESATIVAR
  EXCLUIR
}

model EquipeOption {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PerguntaSeguranca {
  id        Int      @id @default(autoincrement())
  texto     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  entity    String
  entityId  Int?
  action    AuditAction
  userId    Int?
  userName  String?
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())
}

model RelatorioLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  userName      String?
  matricula     String?
  tipoRelatorio String
  createdAt     DateTime @default(now())
}

model ErroLog {
  id          Int      @id @default(autoincrement())
  mensagem    String
  stack       String?
  endpoint    String?
  metodo      String?
  userId      Int?
  userName    String?
  matricula   String?
  ip          String?
  userAgent   String?
  requestBody Json?
  statusCode  Int?
  erro        Json?
  createdAt   DateTime @default(now())
}

model AcessoLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  userName    String?
  matricula   String?
  ip          String?
  userAgent   String?
  dataEntrada DateTime  @default(now())
  dataSaida   DateTime?
  tempoSessao Int? // Tempo em segundos
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RestricaoMedica {
  id        Int                        @id @default(autoincrement())
  nome      String                     @unique
  descricao String?
  policiais Policial[]
  historico RestricaoMedicaHistorico[]
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
}

model RestricaoMedicaHistorico {
  id                Int             @id @default(autoincrement())
  policialId        Int
  policial          Policial        @relation(fields: [policialId], references: [id], onDelete: Cascade)
  restricaoMedicaId Int
  restricaoMedica   RestricaoMedica @relation(fields: [restricaoMedicaId], references: [id])
  dataInicio        DateTime // Quando a restrição foi colocada
  dataFim           DateTime // Quando a restrição foi removida
  observacao        String?
  removidoPorId     Int?
  removidoPorNome   String?
  createdAt         DateTime        @default(now())
}

model TipoRestricaoAfastamento {
  id         Int                    @id @default(autoincrement())
  nome       String                 @unique
  descricao  String?
  restricoes RestricaoAfastamento[]
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
}

model RestricaoAfastamento {
  id               Int                      @id @default(autoincrement())
  tipoRestricaoId  Int
  tipoRestricao    TipoRestricaoAfastamento @relation(fields: [tipoRestricaoId], references: [id])
  ano              Int // Ano da restrição (ex: 2026, 2027)
  dataInicio       DateTime
  dataFim          DateTime
  motivosRestritos Int[] // Array de IDs de MotivoAfastamento
  ativo            Boolean                  @default(true)
  createdById      Int?
  createdByName    String?
  updatedById      Int?
  updatedByName    String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model UsuarioNivelPermissao {
  id        Int           @id @default(autoincrement())
  nivelId   Int
  nivel     UsuarioNivel  @relation(fields: [nivelId], references: [id], onDelete: Cascade)
  telaKey   String
  acao      PermissaoAcao
  createdAt DateTime      @default(now())

  @@unique([nivelId, telaKey, acao])
}

model HorarioSvg {
  id        Int      @id @default(autoincrement())
  horaInicio String  // HH:mm
  horaFim    String  // HH:mm
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([horaInicio, horaFim])
}

/** Parâmetros globais: escala 12×24 das equipes operacionais (cinco letras, turnos dia/noite) e escala 24×72 dos motoristas — chaves fixas no serviço. */
model EscalaParametro {
  id            Int      @id @default(autoincrement())
  chave         String   @unique
  valor         String   @db.Text
  updatedAt     DateTime @updatedAt
  updatedById   Int?
  updatedByName String?
}

/** Textos informativos exibidos na tela Geral de Escalas. */
model EscalaInformacao {
  id              Int      @id @default(autoincrement())
  titulo          String
  conteudo        String   @db.Text
  ordem           Int      @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     Int?
  createdByName   String?
  updatedById     Int?
  updatedByName   String?
}

/** Escala gerada e salva (aba Gerar Escalas). tipoServico: OPERACIONAL | EXPEDIENTE | MOTORISTAS. lista: DISPONIVEL | AFASTADO. */
model EscalaGerada {
  id              Int                 @id @default(autoincrement())
  dataEscala      DateTime            @db.Date
  tipoServico     String
  resumoEquipes   String?             @db.Text
  ativo           Boolean             @default(true)
  createdAt       DateTime            @default(now())
  createdById     Int?
  createdByName   String?
  linhas          EscalaGeradaLinha[]
}

model EscalaGeradaLinha {
  id                 Int          @id @default(autoincrement())
  escalaGeradaId     Int
  escalaGerada       EscalaGerada @relation(fields: [escalaGeradaId], references: [id], onDelete: Cascade)
  lista              String
  policialId         Int
  nome               String
  matricula          String
  equipe             String?
  horarioServico     String
  funcaoNome         String?
  detalheAfastamento String?      @db.Text
}

enum TrocaServicoStatus {
  ATIVA
  CONCLUIDA
  CANCELADA
}

/** Turno 12×24 da escala operacional coberto pela troca (revert após o fim desse turno em Brasília). */
enum TrocaServicoTurno {
  DIURNO
  NOTURNO
}

/** Troca temporária de equipe entre dois policiais; após as datas de serviço, equipes de origem são restauradas. */
model TrocaServico {
  id            Int                @id @default(autoincrement())
  policialAId   Int
  policialBId   Int
  policialA     Policial           @relation("TrocaServicoPolicialA", fields: [policialAId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  policialB     Policial           @relation("TrocaServicoPolicialB", fields: [policialBId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  equipeOrigemA String?
  equipeOrigemB String?
  dataServicoA  DateTime           @db.Date
  dataServicoB  DateTime           @db.Date
  turnoServicoA TrocaServicoTurno  @default(NOTURNO)
  turnoServicoB TrocaServicoTurno  @default(NOTURNO)
  restauradoA   Boolean            @default(false)
  restauradoB   Boolean            @default(false)
  status        TrocaServicoStatus @default(ATIVA)
  createdById   Int?
  createdByName String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status])
  @@index([policialAId])
  @@index([policialBId])
}

enum ErrorReportStatus {
  ABERTO
  EM_ANALISE
  RESOLVIDO
  FECHADO
  CANCELADO
}

enum ErrorReportCategoria {
  ERRO_SISTEMA
  DUVIDA
  MELHORIA
  OUTRO
}

/** Contador sequencial por ano civil (America/Sao_Paulo): os 5 últimos dígitos do protocolo reiniciam em 01/01. */
model ErrorReportProtocolSequence {
  anoReferencia String @id @db.VarChar(4)
  contador      Int    @default(0)

  @@map("error_report_protocol_sequence")
}

/** Chamados de erro / suporte registrados pelos usuários. Coluna de histórico `acoes` guarda todas as ações (criação, comentários, mudança de status). */
model ErrorReport {
  id        Int                  @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /** Protocolo numérico de 15 dígitos (ano + categoria + mês + dia + ordem no ano). */
  protocolo String               @unique @db.VarChar(15)
  descricao String               @db.Text
  categoria ErrorReportCategoria
  status    ErrorReportStatus    @default(ABERTO)
  acoes          Json    @default("[]")
  /** Data URL (base64) de imagem ou PDF anexado pelo solicitante; opcional. */
  anexoDataUrl   String? @db.Text
  /** Nome original do arquivo enviado (exibição / download). */
  anexoNome      String? @db.VarChar(255)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@map("errorReport")
}
