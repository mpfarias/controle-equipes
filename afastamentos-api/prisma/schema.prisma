generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Policial {
  id                Int              @id @default(autoincrement())
  nome              String
  matricula         String           @unique
  equipe            Equipe?
  status            PolicialStatus   @default(ATIVO)
  funcaoId          Int?
  funcao            Funcao?          @relation(fields: [funcaoId], references: [id])
  restricaoMedicaId Int?
  restricaoMedica   RestricaoMedica? @relation(fields: [restricaoMedicaId], references: [id])
  fotoUrl           String?
  afastamentos      Afastamento[]
  createdById       Int?
  createdByName     String?
  updatedById       Int?
  updatedByName     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model MotivoAfastamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  descricao    String?
  afastamentos Afastamento[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Afastamento {
  id            Int               @id @default(autoincrement())
  policialId    Int
  policial      Policial          @relation(fields: [policialId], references: [id], onDelete: Cascade)
  motivoId      Int
  motivo        MotivoAfastamento @relation(fields: [motivoId], references: [id])
  seiNumero     String
  descricao     String?
  dataInicio    DateTime
  dataFim       DateTime?
  status        AfastamentoStatus @default(ATIVO)
  createdById   Int?
  createdByName String?
  updatedById   Int?
  updatedByName String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model UsuarioNivel {
  id        Int       @id @default(autoincrement())
  nome      String    @unique
  descricao String?
  usuarios  Usuario[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Funcao {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  descricao String?
  usuarios  Usuario[]
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Usuario {
  id                    Int           @id @default(autoincrement())
  nome                  String
  matricula             String        @unique
  senhaHash             String
  perguntaSeguranca     String?
  respostaSegurancaHash String?
  equipe                Equipe        @default(A)
  status                UsuarioStatus @default(ATIVO)
  isAdmin               Boolean       @default(false)
  nivelId               Int?
  nivel                 UsuarioNivel? @relation(fields: [nivelId], references: [id])
  funcaoId              Int?
  funcao                Funcao?       @relation(fields: [funcaoId], references: [id])
  createdById           Int?
  createdByName         String?
  updatedById           Int?
  updatedByName         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum AfastamentoStatus {
  ATIVO
  ENCERRADO
}

enum PolicialStatus {
  ATIVO
  DESIGNADO
  COMISSIONADO
  PTTC
  DESATIVADO
}

enum UsuarioStatus {
  ATIVO
  DESATIVADO
}

enum Equipe {
  A
  B
  C
  D
  E
  SEM_EQUIPE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  entity    String
  entityId  Int?
  action    AuditAction
  userId    Int?
  userName  String?
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())
}

model RelatorioLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  userName      String?
  matricula     String?
  tipoRelatorio String
  createdAt     DateTime @default(now())
}

model ErroLog {
  id            Int      @id @default(autoincrement())
  mensagem      String
  stack         String?
  endpoint      String?
  metodo        String?
  userId        Int?
  userName      String?
  matricula     String?
  ip            String?
  userAgent     String?
  requestBody   Json?
  statusCode    Int?
  erro          Json?
  createdAt     DateTime @default(now())
}

model AcessoLog {
  id            Int       @id @default(autoincrement())
  userId        Int?
  userName      String?
  matricula     String?
  ip            String?
  userAgent     String?
  dataEntrada   DateTime  @default(now())
  dataSaida     DateTime?
  tempoSessao   Int?      // Tempo em minutos
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RestricaoMedica {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  descricao String?
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TipoRestricaoAfastamento {
  id                Int                      @id @default(autoincrement())
  nome              String                   @unique
  descricao         String?
  restricoes        RestricaoAfastamento[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
}

model RestricaoAfastamento {
  id                      Int                        @id @default(autoincrement())
  tipoRestricaoId         Int
  tipoRestricao           TipoRestricaoAfastamento   @relation(fields: [tipoRestricaoId], references: [id])
  ano                     Int                        // Ano da restrição (ex: 2026, 2027)
  dataInicio              DateTime
  dataFim                 DateTime
  motivosRestritos        Int[]                      // Array de IDs de MotivoAfastamento
  ativo                   Boolean                    @default(true)
  createdById             Int?
  createdByName           String?
  updatedById             Int?
  updatedByName           String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
}
