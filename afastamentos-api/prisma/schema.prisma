generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Colaborador {
  id            Int             @id @default(autoincrement())
  nome          String
  matricula     String          @unique
  equipe        Equipe          @default(A)
  status        PolicialStatus  @default(ATIVO)
  afastamentos  Afastamento[]
  createdById   Int?
  createdByName String?
  updatedById   Int?
  updatedByName String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model MotivoAfastamento {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  descricao   String?
  afastamentos Afastamento[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Afastamento {
  id             Int                @id @default(autoincrement())
  colaboradorId  Int
  colaborador    Colaborador        @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  motivoId       Int
  motivo         MotivoAfastamento  @relation(fields: [motivoId], references: [id])
  descricao      String?
  dataInicio     DateTime
  dataFim        DateTime?
  status         AfastamentoStatus  @default(ATIVO)
  createdById    Int?
  createdByName  String?
  updatedById    Int?
  updatedByName  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model UsuarioNivel {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descricao   String?
  usuarios    Usuario[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Funcao {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descricao   String?
  usuarios    Usuario[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nome       String
  matricula  String   @unique
  senhaHash  String
  perguntaSeguranca String?
  respostaSegurancaHash String?
  equipe     Equipe   @default(A)
  status     UsuarioStatus @default(ATIVO)
  isAdmin    Boolean  @default(false)
  nivelId    Int?
  nivel      UsuarioNivel? @relation(fields: [nivelId], references: [id])
  funcaoId   Int?
  funcao     Funcao?  @relation(fields: [funcaoId], references: [id])
  createdById   Int?
  createdByName String?
  updatedById   Int?
  updatedByName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum AfastamentoStatus {
  ATIVO
  ENCERRADO
}

enum PolicialStatus {
  ATIVO
  DESIGNADO
  COMISSIONADO
  PTTC
  DESATIVADO
}

enum UsuarioStatus {
  ATIVO
  DESATIVADO
}

enum Equipe {
  A
  B
  C
  D
  E
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        Int          @id @default(autoincrement())
  entity    String
  entityId  Int?
  action    AuditAction
  userId    Int?
  userName  String?
  before    Json?
  after     Json?
  createdAt DateTime     @default(now())
}

