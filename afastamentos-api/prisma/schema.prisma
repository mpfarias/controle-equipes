generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PostoGraduacao {
  id        Int        @id @default(autoincrement())
  sigla     String     @unique @db.VarChar(40)
  ordem     Int        @unique
  ativo     Boolean    @default(true)
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("posto_graduacao")
}

enum QuadroGrupo {
  OFICIAL
  PRACA
}

model Quadro {
  id        Int         @id @default(autoincrement())
  sigla     String      @unique @db.VarChar(20)
  grupo     QuadroGrupo
  ordem     Int
  ativo     Boolean     @default(true)
  policiais Policial[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([grupo, ordem])
  @@map("quadro")
}

enum PolicialSexo {
  MASCULINO
  FEMININO
}

enum PolicialCategoriaCnh {
  A
  AB
  B
  C
  D
  E
}

model Policial {
  id                         Int                        @id @default(autoincrement())
  postoGraduacaoId           Int?
  postoGraduacao             PostoGraduacao?            @relation(fields: [postoGraduacaoId], references: [id], onDelete: SetNull)
  quadroId                   Int?
  quadro                     Quadro?                    @relation(fields: [quadroId], references: [id], onDelete: SetNull)
  nome                       String
  matricula                  String                     @unique
  cpf                        String?
  telefone                   String?
  dataNascimento             DateTime?
  email                      String?
  sexo                       PolicialSexo?
  dataAdmissao               DateTime?                  @db.Date
  cep                        String?                    @db.VarChar(8)
  logradouro                 String?                    @db.VarChar(255)
  complemento                String?                    @db.VarChar(100)
  cidade                     String?                    @db.VarChar(120)
  estado                     String?                    @db.VarChar(2)
  enderecoSemCep             Boolean                    @default(false)
  contatoEmergenciaNome      String?                    @db.VarChar(200)
  contatoEmergenciaTelefone  String?                    @db.VarChar(11)
  /** 0–5 = quantidade exata; 6 = «6 ou mais». */
  quantidadeDependentes      Int?
  /** [{ nome, condicao: CONJUGE|FILHO|OUTROS, condicaoOutros? }] */
  dependentes                Json                       @default("[]")
  doadorOrgaos               Boolean?
  categoriaCnh               PolicialCategoriaCnh?
  cnhNaoHabilitado           Boolean                    @default(false)
  /** Lista de formações de nível superior. */
  nivelSuperiorEm            Json                       @default("[]")
  /** Lista de cursos civis e/ou militares. */
  cursosCivisMilitares       Json                       @default("[]")
  matriculaComissionadoGdf   String?
  dataPosse                  DateTime?
  equipe                     String?
  statusId                   Int
  status                     StatusPolicial             @relation(fields: [statusId], references: [id])
  funcaoId                   Int?
  funcao                     Funcao?                    @relation(fields: [funcaoId], references: [id])
  restricaoMedicaId          Int?
  restricaoMedica            RestricaoMedica?           @relation(fields: [restricaoMedicaId], references: [id])
  restricaoMedicaObservacao  String?
  restricaoMedicaDataInicio  DateTime?
  restricaoMedicaDataFim     DateTime?
  restricaoMedicaPermanente  Boolean                    @default(false)
  restricoesMedicasHistorico RestricaoMedicaHistorico[]
  fotoUrl                    String?
  ferias                     FeriasPolicial[]
  afastamentos               Afastamento[]
  trocasServicoComoA         TrocaServico[]             @relation("TrocaServicoPolicialA")
  trocasServicoComoB         TrocaServico[]             @relation("TrocaServicoPolicialB")
  createdById                Int?
  createdByName              String?
  updatedById                Int?
  updatedByName              String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  dataDesativacaoAPartirDe   DateTime?
  observacoesDesativacao     String?
  desativadoPorId            Int?
  desativadoPorNome          String?
  desativadoEm               DateTime?
  contagemEscalaExtra        PolicialContagemEscalaExtra?
  expediente12x36Fase        PolicialExpediente12x36Fase?
  orionAgendaCompromissos    OrionAgendaCompromisso[]
  orionAgendaParticipacoes   OrionAgendaCompromissoParticipante[]
}

model StatusPolicial {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  descricao String?
  policiais Policial[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model FeriasPolicial {
  id                 Int       @id @default(autoincrement())
  policialId         Int
  policial           Policial  @relation(fields: [policialId], references: [id], onDelete: Cascade)
  ano                Int
  dataInicio         DateTime
  dataFim            DateTime
  /** Exercícios anteriores ao ano civil: permite cadastrar só o ano; datas são placeholder (jan.) até definir o mês. */
  semMesDefinido     Boolean   @default(false)
  confirmada         Boolean   @default(false)
  reprogramada       Boolean   @default(false)
  dataInicioOriginal DateTime?
  dataFimOriginal    DateTime?
  createdById        Int?
  createdByName      String?
  updatedById        Int?
  updatedByName      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([policialId, ano])
}

model MotivoAfastamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  descricao    String?
  afastamentos Afastamento[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Afastamento {
  id            Int               @id @default(autoincrement())
  policialId    Int
  policial      Policial          @relation(fields: [policialId], references: [id], onDelete: Cascade)
  motivoId      Int
  motivo        MotivoAfastamento @relation(fields: [motivoId], references: [id])
  seiNumero     String
  descricao     String?
  /**
   * Ano da cota de férias (exercício) quando o gozo é em outro ano (ex.: direito de 2024, gozo em 2026).
   * Nulo = considerar o ano civil da data de início (comportamento legado).
   */
  anoExercicioFerias Int?
  dataInicio    DateTime
  dataFim       DateTime?
  status        AfastamentoStatus @default(ATIVO)
  /** Preenchido ao desativar manualmente ou pelo encerramento automático (fim do período). */
  desativadoPorId   Int?
  desativadoPorNome String?
  desativadoEm      DateTime?
  createdById   Int?
  createdByName String?
  updatedById   Int?
  updatedByName String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model UsuarioNivel {
  id         Int                     @id @default(autoincrement())
  nome       String                  @unique
  descricao  String?
  ativo      Boolean                 @default(true)
  /** Quando true, usuários deste nível podem acessar o app Órion Suporte (gestão de chamados). */
  acessoOrionSuporte Boolean         @default(false)
  usuarios   Usuario[]
  permissoes UsuarioNivelPermissao[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
}

enum FuncaoVinculoEquipe {
  OBRIGATORIA
  OPCIONAL
  SEM_EQUIPE
}

/** Horário no expediente quando `escalaExpediente`; AUTO = regras legadas por nome em `expedienteEscalaRegras`. */
enum FuncaoExpedienteHorarioPreset {
  AUTO
  ORGAO_DIAS_UTEIS
  SEG_SEX_07_19
  SEG_SEX_12X36_SEMANA_ALTERNADA
  JORNADA_24X72
  /** Guarda COPOM: 12×36 seg–sex (seg/qua/sex × ter/qui, alternância quinzenal). */
  GUARDA_COPOM_12X36
}

/** Complemento ao preset 12×36 semanal (semana ISO par vs ímpar), por policial. */
enum PolicialExpediente12x36Fase {
  PAR
  IMPAR
}

model Funcao {
  id             Int                  @id @default(autoincrement())
  nome           String               @unique
  descricao      String?
  ativo          Boolean              @default(true)
  /** Como a equipe (A–E) se aplica ao policial com esta função. */
  vinculoEquipe  FuncaoVinculoEquipe  @default(OBRIGATORIA)
  /** Inclui o policial na geração «Operacional» (12×24), se tiver equipe válida. */
  escalaOperacional Boolean           @default(true)
  /** Policial entra na geração «Motoristas» (24×72); exclui do operacional. */
  escalaMotorista   Boolean           @default(false)
  /** Policial entra na geração «Expediente» (horários em expedienteEscalaRegras). */
  escalaExpediente  Boolean           @default(false)
  expedienteHorarioPreset FuncaoExpedienteHorarioPreset @default(AUTO)
  /** Quando a função pertence a uma equipe fixa (A, B, C...), todos os policiais da função herdam essa equipe. */
  equipeReferencia  String?
  usuarios       Usuario[]
  policiais      Policial[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Usuario {
  id                    Int           @id @default(autoincrement())
  nome                  String
  matricula             String        @unique
  senhaHash             String
  perguntaSeguranca     String?
  respostaSegurancaHash String?
  equipe                String?
  status                UsuarioStatus @default(ATIVO)
  isAdmin               Boolean       @default(false)
  nivelId               Int?
  nivel                 UsuarioNivel? @relation(fields: [nivelId], references: [id])
  nivelRemovidoEm       DateTime?     // Quando o nível foi excluído e o usuário ficou sem nível
  funcaoId              Int?
  funcao                Funcao?       @relation(fields: [funcaoId], references: [id])
  fotoUrl               String?
  /**
   * Órion Suporte: null = herdar do nível; true = garantir acesso; false = bloquear mesmo que o nível conceda.
   */
  acessoOrionSuporte    Boolean?
  /** SPAs do ecossistema: SAD, OPERACOES, ORION_QUALIDADE, ORION_JURIDICO, ORION_PATRIMONIO, ORION_MULHER, … (ver `SISTEMAS_EXTERNOS_IDS` na API). */
  sistemasPermitidos    String[]      @default([])
  createdById           Int?
  createdByName         String?
  updatedById           Int?
  updatedByName         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  errorReports          ErrorReport[]
  /** Registros criados no módulo Órion Qualidade. */
  qualidadeRegistrosCriados QualidadeRegistro[] @relation("QualidadeRegistroAutor")
  /** Bens cadastrados no módulo Órion Patrimônio. */
  patrimonioBensCriados PatrimonioBem[] @relation("PatrimonioBemAutor")
  /** Compromissos da agenda do Órion Agenda. */
  orionAgendaCompromissosCriados OrionAgendaCompromisso[] @relation("OrionAgendaAutor")
  /** Órion Mulher — ocorrências e central da vítima. */
  mulherOcorrenciasCriadas     MulherOcorrencia[]         @relation("MulherOcorrenciaAutor")
  mulherOcorrenciasAtualizadas MulherOcorrencia[]         @relation("MulherOcorrenciaEditor")
  mulherTelemetriaAcks         MulherTelemetriaMobile[]   @relation("MulherTelemetriaAck")
  mulherVitimaPanicoAcks       MulherVitimaPanicoMobile[] @relation("MulherVitimaPanicoAck")
  mulherOperadorPerfil         MulherOperadorPerfil?
}

enum AfastamentoStatus {
  ATIVO
  /** Fim automático após o término do período (data fim). */
  ENCERRADO
  /** Desativação manual no sistema; mantém auditoria em desativadoPor* / desativadoEm. */
  DESATIVADO
}

enum UsuarioStatus {
  ATIVO
  DESATIVADO
}

/** Ciclo de vida de um registro de gestão da qualidade (Órion Qualidade). */
enum QualidadeRegistroStatus {
  ABERTO
  EM_TRATAMENTO
  ENCERRADO
}

/**
 * Registro de oportunidade de melhoria / não conformidade leve / acompanhamento de qualidade.
 * Acesso à API restrito a quem tem `ORION_QUALIDADE` em sistemasPermitidos (cadastro no SAD).
 */
model QualidadeRegistro {
  id                Int                     @id @default(autoincrement())
  titulo            String
  descricao         String?                 @db.Text
  status            QualidadeRegistroStatus @default(ABERTO)
  criadoPorId       Int
  criadoPor         Usuario                 @relation("QualidadeRegistroAutor", fields: [criadoPorId], references: [id])
  criadoPorNome     String
  atualizadoPorId   Int?
  atualizadoPorNome String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([criadoPorId])
  @@index([status])
  @@map("qualidade_registro")
}

/** Situação do bem no acervo do COPOM (Órion Patrimônio). */
enum PatrimonioBemSituacao {
  EM_USO
  GUARDADO
  MANUTENCAO
  EMPRESTADO
  BAIXADO
}

/**
 * Bem patrimonial tombado. Acesso à API restrito a quem tem `ORION_PATRIMONIO` em sistemasPermitidos.
 */
model PatrimonioBem {
  id                Int                   @id @default(autoincrement())
  tombamento        String                @unique @db.VarChar(64)
  descricao         String                @db.VarChar(500)
  categoria         String?               @db.VarChar(120)
  marca             String?               @db.VarChar(120)
  modelo            String?               @db.VarChar(120)
  numeroSerie       String?               @db.VarChar(120)
  localizacaoSetor  String?               @db.VarChar(200)
  situacao          PatrimonioBemSituacao @default(EM_USO)
  observacoes       String?               @db.Text
  dataAquisicao     DateTime?             @db.Date
  valorAquisicao    Decimal?              @db.Decimal(14, 2)
  criadoPorId       Int
  criadoPor         Usuario               @relation("PatrimonioBemAutor", fields: [criadoPorId], references: [id])
  criadoPorNome     String                @db.VarChar(200)
  atualizadoPorId   Int?
  atualizadoPorNome String?               @db.VarChar(200)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([situacao])
  @@index([criadoPorId])
  @@index([tombamento])
  @@map("patrimonio_bem")
}

enum PermissaoAcao {
  VISUALIZAR
  EDITAR
  DESATIVAR
  EXCLUIR
}

model EquipeOption {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PerguntaSeguranca {
  id        Int      @id @default(autoincrement())
  texto     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  entity    String
  entityId  Int?
  action    AuditAction
  userId    Int?
  userName  String?
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())
}

model RelatorioLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  userName      String?
  matricula     String?
  tipoRelatorio String
  createdAt     DateTime @default(now())
}

model ErroLog {
  id          Int      @id @default(autoincrement())
  mensagem    String
  stack       String?
  endpoint    String?
  metodo      String?
  userId      Int?
  userName    String?
  matricula   String?
  ip          String?
  userAgent   String?
  requestBody Json?
  statusCode  Int?
  erro        Json?
  createdAt   DateTime @default(now())
}

model AcessoLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  userName    String?
  matricula   String?
  ip          String?
  userAgent   String?
  dataEntrada DateTime  @default(now())
  dataSaida   DateTime?
  tempoSessao Int? // Tempo em segundos
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RestricaoMedica {
  id        Int                        @id @default(autoincrement())
  nome      String                     @unique
  descricao String?
  policiais Policial[]
  historico RestricaoMedicaHistorico[]
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
}

model RestricaoMedicaHistorico {
  id                Int             @id @default(autoincrement())
  policialId        Int
  policial          Policial        @relation(fields: [policialId], references: [id], onDelete: Cascade)
  restricaoMedicaId Int
  restricaoMedica   RestricaoMedica @relation(fields: [restricaoMedicaId], references: [id])
  dataInicio        DateTime // Quando a restrição foi colocada
  dataFim           DateTime // Quando a restrição foi removida
  observacao        String?
  removidoPorId     Int?
  removidoPorNome   String?
  createdAt         DateTime        @default(now())
}

model TipoRestricaoAfastamento {
  id         Int                    @id @default(autoincrement())
  nome       String                 @unique
  descricao  String?
  restricoes RestricaoAfastamento[]
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
}

model RestricaoAfastamento {
  id               Int                      @id @default(autoincrement())
  tipoRestricaoId  Int
  tipoRestricao    TipoRestricaoAfastamento @relation(fields: [tipoRestricaoId], references: [id])
  ano              Int // Ano da restrição (ex: 2026, 2027)
  dataInicio       DateTime
  dataFim          DateTime
  motivosRestritos Int[] // Array de IDs de MotivoAfastamento
  ativo            Boolean                  @default(true)
  createdById      Int?
  createdByName    String?
  updatedById      Int?
  updatedByName    String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model UsuarioNivelPermissao {
  id        Int           @id @default(autoincrement())
  nivelId   Int
  nivel     UsuarioNivel  @relation(fields: [nivelId], references: [id], onDelete: Cascade)
  telaKey   String
  acao      PermissaoAcao
  createdAt DateTime      @default(now())

  @@unique([nivelId, telaKey, acao])
}

model HorarioSvg {
  id        Int      @id @default(autoincrement())
  horaInicio String  // HH:mm
  horaFim    String  // HH:mm
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([horaInicio, horaFim])
}

/** Parâmetros globais: escala 12×24 das equipes operacionais (cinco letras, turnos dia/noite) e escala 24×72 dos motoristas — chaves fixas no serviço. */
model EscalaParametro {
  id            Int      @id @default(autoincrement())
  chave         String   @unique
  valor         String   @db.Text
  updatedAt     DateTime @updatedAt
  updatedById   Int?
  updatedByName String?
}

/** Textos informativos exibidos na tela Geral de Escalas. */
model EscalaInformacao {
  id              Int      @id @default(autoincrement())
  titulo          String
  conteudo        String   @db.Text
  ordem           Int      @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     Int?
  createdByName   String?
  updatedById     Int?
  updatedByName   String?
}

/** Escala gerada e salva (aba Gerar Escalas / escala extraordinária). tipoServico: OPERACIONAL | EXPEDIENTE | MOTORISTAS | EXTRAORDINARIA. lista: DISPONIVEL | AFASTADO. */
model EscalaGerada {
  id              Int                 @id @default(autoincrement())
  dataEscala      DateTime            @db.Date
  tipoServico     String
  resumoEquipes   String?             @db.Text
  /** Snapshot JSON do payload de impressão definitiva (linhas com bloco, cabeçalhos por bloco, data de geração). */
  impressaoDraft  Json?
  ativo           Boolean             @default(true)
  createdAt       DateTime            @default(now())
  createdById     Int?
  createdByName   String?
  linhas          EscalaGeradaLinha[]
}

model EscalaGeradaLinha {
  id                 Int          @id @default(autoincrement())
  escalaGeradaId     Int
  escalaGerada       EscalaGerada @relation(fields: [escalaGeradaId], references: [id], onDelete: Cascade)
  lista              String
  policialId         Int
  nome               String
  matricula          String
  equipe             String?
  horarioServico     String
  funcaoNome         String?
  detalheAfastamento String?      @db.Text
}

/**
 * Quantas vezes o policial entrou em uma escala extraordinária **salva** (POST /escalas/geradas com EXTRAORDINARIA).
 * +1 por policial distinto por gravação (mesma escala com o mesmo policial em várias linhas conta uma vez).
 */
model PolicialContagemEscalaExtra {
  policialId         Int      @id
  policial           Policial @relation(fields: [policialId], references: [id], onDelete: Cascade)
  vezesEscaladoExtra Int      @default(0)
  updatedAt          DateTime @updatedAt
}

enum TrocaServicoStatus {
  ATIVA
  CONCLUIDA
  CANCELADA
}

/** Turno 12×24 da escala operacional coberto pela troca (revert após o fim desse turno em Brasília). */
enum TrocaServicoTurno {
  DIURNO
  NOTURNO
}

/** Troca temporária de equipe entre dois policiais; após as datas de serviço, equipes de origem são restauradas. */
model TrocaServico {
  id            Int                @id @default(autoincrement())
  policialAId   Int
  policialBId   Int
  policialA     Policial           @relation("TrocaServicoPolicialA", fields: [policialAId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  policialB     Policial           @relation("TrocaServicoPolicialB", fields: [policialBId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  equipeOrigemA String?
  equipeOrigemB String?
  dataServicoA  DateTime           @db.Date
  dataServicoB  DateTime           @db.Date
  turnoServicoA TrocaServicoTurno  @default(NOTURNO)
  turnoServicoB TrocaServicoTurno  @default(NOTURNO)
  restauradoA   Boolean            @default(false)
  restauradoB   Boolean            @default(false)
  status        TrocaServicoStatus @default(ATIVA)
  createdById   Int?
  createdByName String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status])
  @@index([policialAId])
  @@index([policialBId])
}

enum ErrorReportStatus {
  ABERTO
  EM_ANALISE
  RESOLVIDO
  FECHADO
  CANCELADO
}

enum ErrorReportCategoria {
  ERRO_SISTEMA
  DUVIDA
  MELHORIA
  OUTRO
}

/** Contador sequencial por ano civil (America/Sao_Paulo): os 5 últimos dígitos do protocolo reiniciam em 01/01. */
model ErrorReportProtocolSequence {
  anoReferencia String @id @db.VarChar(4)
  contador      Int    @default(0)

  @@map("error_report_protocol_sequence")
}

/** Chamados de erro / suporte registrados pelos usuários. Coluna de histórico `acoes` guarda todas as ações (criação, comentários, mudança de status). */
model ErrorReport {
  id        Int                  @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /** Protocolo numérico de 15 dígitos (ano + categoria + mês + dia + ordem no ano). */
  protocolo String               @unique @db.VarChar(15)
  descricao String               @db.Text
  categoria ErrorReportCategoria
  status    ErrorReportStatus    @default(ABERTO)
  acoes          Json    @default("[]")
  /** Data URL (base64) de imagem ou PDF anexado pelo solicitante; opcional. */
  anexoDataUrl   String? @db.Text
  /** Nome original do arquivo enviado (exibição / download). */
  anexoNome      String? @db.VarChar(255)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@map("errorReport")
}

/** Tipo de compromisso na agenda (Órion Agenda). */
enum OrionAgendaTipo {
  REUNIAO
  PALESTRA
  PRAZO
  AUDIENCIA
  OUTRO
}

enum OrionAgendaStatus {
  AGENDADO
  CONCLUIDO
  CANCELADO
}

/**
 * Compromisso da agenda institucional (reuniões, prazos, audiências).
 * Acesso restrito a quem tem `ORION_AGENDA` em sistemasPermitidos.
 */
model OrionAgendaCompromisso {
  id                Int               @id @default(autoincrement())
  titulo            String            @db.VarChar(300)
  descricao         String?           @db.Text
  dataInicio        DateTime
  dataFim           DateTime?
  diaInteiro        Boolean           @default(false)
  local             String?           @db.VarChar(300)
  tipo              OrionAgendaTipo   @default(REUNIAO)
  status            OrionAgendaStatus @default(AGENDADO)
  policialId        Int?
  policial          Policial?         @relation(fields: [policialId], references: [id], onDelete: SetNull)
  responsavelNome   String?           @db.VarChar(200)
  criadoPorId       Int
  criadoPor         Usuario           @relation("OrionAgendaAutor", fields: [criadoPorId], references: [id])
  criadoPorNome     String            @db.VarChar(200)
  atualizadoPorId   Int?
  atualizadoPorNome String?           @db.VarChar(200)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  participantes     OrionAgendaCompromissoParticipante[]

  @@index([dataInicio])
  @@index([status])
  @@index([criadoPorId])
  @@index([policialId])
  @@map("orion_agenda_compromisso")
}

model OrionAgendaCompromissoParticipante {
  id            Int                    @id @default(autoincrement())
  compromissoId Int
  compromisso   OrionAgendaCompromisso @relation(fields: [compromissoId], references: [id], onDelete: Cascade)
  policialId    Int
  policial      Policial               @relation(fields: [policialId], references: [id], onDelete: Cascade)
  policialNome  String                 @db.VarChar(200)
  ordem         Int                    @default(0)

  @@unique([compromissoId, policialId])
  @@index([compromissoId])
  @@index([policialId])
  @@map("orion_agenda_compromisso_participante")
}

// ─── Órion Mulher (integração sisCopomMulher) ───────────────────────────────

enum MulherOperadorPerfilEnum {
  ADMINISTRADOR
  ATENDENTE
  CONSULTA
}

enum MulherOrigemOcorrencia {
  SISTEMA
  IMPORTACAO_EXCEL
}

enum MulherTelemetriaKind {
  LOCATION
  PANIC
}

enum MulherVitimaPanicEncaminhamento {
  VIATURA_DESPACHADA
  CONTATO_TELEFONE
  ALERTA_FALSO
  DADOS_INCOMPATIVEIS
  LOCALIZACAO_NAO_ENCONTRADA
}

enum MulherVitimaPanicFinalizacao {
  RESOLVIDO_NO_LOCAL
  ENCAMINHADA_DELEGACIA
  AVERIGUADA_NADA_CONSTATADO
  TCO_NO_LOCAL
  ORIENTACAO_PARTES
}

/** Perfil operacional no Órion Mulher (complementa `ORION_MULHER` em sistemasPermitidos). */
model MulherOperadorPerfil {
  id        Int                      @id @default(autoincrement())
  usuarioId Int                      @unique
  usuario   Usuario                  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  perfil    MulherOperadorPerfilEnum @default(ATENDENTE)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@map("mulher_operador_perfil")
}

model MulherAuditoria {
  id          String   @id @default(cuid())
  usuarioId   Int?
  usuarioNome String?  @db.VarChar(200)
  acao        String   @db.VarChar(120)
  entidade    String   @db.VarChar(80)
  entidadeId  String?  @db.VarChar(80)
  detalhes    String?  @db.Text
  ip          String?  @db.VarChar(64)
  userAgent   String?  @db.VarChar(500)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([usuarioId])
  @@map("mulher_auditoria")
}

model MulherOcorrencia {
  id        String                 @id @default(cuid())
  origem    MulherOrigemOcorrencia @default(SISTEMA)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  criadoPorId     Int?
  criadoPor       Usuario? @relation("MulherOcorrenciaAutor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  atualizadoPorId Int?
  atualizadoPor   Usuario? @relation("MulherOcorrenciaEditor", fields: [atualizadoPorId], references: [id], onDelete: SetNull)

  faseAtual Int     @default(1)
  concluida Boolean @default(false)

  carimboDataHora          DateTime?
  nomeVitima               String?
  enderecoVitima           String?
  telefoneVitima           String?
  telefoneVitimaSecundario String?
  cpfVitima                String?
  dataNascimentoVitima     DateTime?
  genitoraVitima           String?
  pontoReferencia          String?

  dataHoraOcorrencia  DateTime?
  regiaoAdministrativa String?
  historicoOcorrencia  String? @db.Text

  nomeAgressor             String?
  enderecoAgressor         String?
  parentescoAgressorVitima String?
  tipoAmeacaAgressao       String?
  agressorEnvolvimento     String?
  idadeAgressor            String?

  nomeDenunciante     String?
  enderecoDenunciante String?
  telefoneDenunciante String?

  comandanteViatura      String?
  responsavelAtendimento String?
  encaminhamentoDetalhes String? @db.Text

  desfecho            String?
  registrouBoDp       String?
  numeroOcorrenciaCad String?

  linksMobile MulherOcorrenciaLinkMobile[]

  @@index([regiaoAdministrativa])
  @@index([nomeVitima])
  @@index([nomeAgressor])
  @@index([dataHoraOcorrencia])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([origem])
  @@map("mulher_ocorrencia")
}

model MulherOcorrenciaLinkMobile {
  id           String         @id @default(cuid())
  ocorrenciaId String
  ocorrencia   MulherOcorrencia @relation(fields: [ocorrenciaId], references: [id], onDelete: Cascade)
  tokenHash    String         @unique
  label        String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastSeenAt   DateTime?
  createdAt    DateTime       @default(now())
  criadoPorId  Int?

  eventos MulherTelemetriaMobile[]

  @@index([ocorrenciaId])
  @@map("mulher_ocorrencia_link_mobile")
}

model MulherTelemetriaMobile {
  id               String                   @id @default(cuid())
  linkId           String
  link             MulherOcorrenciaLinkMobile @relation(fields: [linkId], references: [id], onDelete: Cascade)
  kind             MulherTelemetriaKind
  latitude         Float
  longitude        Float
  accuracyM        Float?
  altitude         Float?
  speed            Float?
  heading          Float?
  deviceInfo       String?
  createdAt        DateTime                 @default(now())
  acknowledgedAt   DateTime?
  acknowledgedById Int?
  acknowledgedBy   Usuario?                 @relation("MulherTelemetriaAck", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([linkId, createdAt])
  @@index([kind, createdAt])
  @@map("mulher_telemetria_mobile")
}

model MulherVitimaCadastroMobile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  telefoneDigits String

  nomeVitima         String?
  idade              String?
  cpf                String?
  identidade         String?
  medidaProtetiva    String?
  enderecoResidencia String?
  latitude           Float?
  longitude          Float?
  accuracyM          Float?

  nomeAgressor     String?
  enderecoAgressor String?

  fotoVitimaNome   String?
  fotoAgressorNome String?

  panicos MulherVitimaPanicoMobile[]

  @@index([telefoneDigits, createdAt])
  @@map("mulher_vitima_cadastro_mobile")
}

model MulherVitimaPanicoMobile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cadastroId String?
  cadastro   MulherVitimaCadastroMobile? @relation(fields: [cadastroId], references: [id], onDelete: Cascade)

  telefoneDigits String
  latitude       Float
  longitude      Float
  accuracyM      Float?

  encaminhamento MulherVitimaPanicEncaminhamento?
  finalizacao    MulherVitimaPanicFinalizacao?

  acknowledgedAt   DateTime?
  acknowledgedById Int?
  acknowledgedBy   Usuario? @relation("MulherVitimaPanicoAck", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([telefoneDigits, createdAt])
  @@map("mulher_vitima_panico_mobile")
}
