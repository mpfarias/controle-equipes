# Copie para .env e ajuste.

# Em LAN, aponte para o host onde a API Nest escuta (mesmo IP do servidor, porta 3002 por padrão).
# VITE_API_URL=http://10.95.91.53:3002

# Órion SAD — URL completa para o item do menu do avatar (opcional; dev usa host atual + 5173)
# VITE_ORION_SAD_URL=http://10.95.91.53:5173
# VITE_ORION_SAD_PORT=5173

# Outros sistemas no menu do avatar (mesmo padrão SAD / Qualidade)
# VITE_ORION_QUALIDADE_URL=http://localhost:5182
# VITE_ORION_QUALIDADE_PORT=5182
# VITE_ORION_JURIDICO_URL=http://localhost:5183
# VITE_ORION_JURIDICO_PORT=5183
# VITE_ORION_PATRIMONIO_URL=http://localhost:5184
# VITE_ORION_PATRIMONIO_PORT=5184
# Órion Mulher (violência doméstica — front reservado na porta 5185)
# VITE_ORION_MULHER_URL=http://localhost:5185
# VITE_ORION_MULHER_PORT=5185
# VITE_ORION_OPERACOES_URL=  (opcional; dev usa host da página + VITE_ORION_OPERACOES_PORT, padrão 5187)
# VITE_ORION_OPERACOES_PORT=
