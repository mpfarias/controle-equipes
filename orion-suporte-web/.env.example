# Copie para .env e ajuste.
# Desenvolvimento: `.env.development` (61xx). Produção local: `.env.production` (51xx).

# Em LAN, aponte para o host onde a API Nest escuta (mesmo IP do servidor, porta 3002 por padrão).
# VITE_API_URL=http://10.95.91.53:3002

# Órion SAD — URL completa para o item do menu do avatar (opcional; dev usa host atual + porta de `.env.development`)
# VITE_ORION_SAD_URL=http://10.95.91.53:5173
# VITE_ORION_SAD_PORT=6173

# Outros sistemas — portas em `.env.development` / `.env.production` (61xx / 51xx)
# VITE_ORION_QUALIDADE_URL=http://localhost:5182
# VITE_ORION_JURIDICO_URL=http://localhost:5183
# VITE_ORION_PATRIMONIO_URL=http://localhost:5184
# VITE_ORION_MULHER_URL=http://localhost:5185
# VITE_ORION_AGENDA_URL=http://localhost:5186
# VITE_ORION_OPERACOES_URL=http://localhost:5187
