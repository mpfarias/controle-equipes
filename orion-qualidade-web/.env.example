# Copie para `.env` na pasta orion-qualidade-web.
#
# Para o aviso «Integra SSP» refletir o .env da API, o front precisa chamar a MESMA instância da API onde
# está definido INTEGRA_SSP_DATABASE_URL (ex.: dev local abaixo). Se VITE_API_URL apontar para outro servidor,
# copie INTEGRA_SSP_DATABASE_URL para o .env desse servidor e reinicie a API.
VITE_API_URL=http://localhost:3002

# Órion SAD — URL para o menu do avatar (handoff JWT; opcional em dev: host atual + 5173)
# VITE_ORION_SAD_URL=http://10.95.91.53:5173
# VITE_ORION_SAD_PORT=5173

# Outros sistemas no menu do avatar (mesmo padrão do SAD)
# VITE_ORION_SUPORTE_URL=http://10.95.91.53:5180
# VITE_ORION_SUPORTE_PORT=5180
# VITE_ORION_JURIDICO_URL=http://10.95.91.53:5183
# VITE_ORION_JURIDICO_PORT=5183
# VITE_ORION_PATRIMONIO_URL=http://10.95.91.53:5184
# VITE_ORION_PATRIMONIO_PORT=5184
# VITE_ORION_MULHER_URL=http://localhost:5185
# VITE_ORION_MULHER_PORT=5185
# VITE_ORION_OPERACOES_URL=
# VITE_ORION_OPERACOES_PORT=

# Vite deste app: http://0.0.0.0:5182 (strictPort), alinhado ao Suporte (5180).
