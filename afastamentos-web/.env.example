# Copie para .env e ajuste conforme o ambiente.

# URL da API (opcional se for localhost:3002 no mesmo host)
# VITE_API_URL=http://10.95.91.53:3002

# Órion Suporte — URL completa (recomendado em LAN, abre do menu do avatar)
# Ex.: mesma máquina que o SAD, porta fixa do Vite do Suporte
# VITE_ORION_SUPORTE_URL=http://10.95.91.53:5180

# Se não usar URL completa: porta do Suporte em dev (padrão 5180)
# VITE_ORION_SUPORTE_PORT=5180

# Órion Qualidade — em dev, suba o Vite: `npm run start:orion-qualidade` na raiz (porta fixa 5182).
# Sem URL abaixo, o SAD usa o mesmo host da página + porta 5182.
# VITE_ORION_QUALIDADE_URL=http://10.95.91.53:5182
# VITE_ORION_QUALIDADE_PORT=5182

# Órion Jurídico
# VITE_ORION_JURIDICO_URL=http://10.95.91.53:5183
# VITE_ORION_JURIDICO_PORT=5183

# Órion Patrimônio (porta dev padrão 5184)
# VITE_ORION_PATRIMONIO_URL=http://10.95.91.53:5184
# VITE_ORION_PATRIMONIO_PORT=5184

# Órion Mulher — violência doméstica (SPA em desenvolvimento; porta dev reservada 5185)
# VITE_ORION_MULHER_URL=http://10.95.91.53:5185
# VITE_ORION_MULHER_PORT=5185

# Órion Assessoria (porta dev padrão 5186)
# VITE_ORION_ASSESSORIA_URL=http://10.95.91.53:5186
# VITE_ORION_ASSESSORIA_PORT=5186
