# Copie para .env e ajuste conforme o ambiente.
# Desenvolvimento local: use `.env.development` (portas 61xx, já versionado).
# Produção local / build: use `.env.production` (portas 51xx, já versionado).

# URL da API (opcional se for localhost:3002 no mesmo host)
# VITE_API_URL=http://10.95.91.53:3002

# Órion Suporte — URL completa (recomendado em LAN, abre do menu do avatar)
# Ex.: mesma máquina que o SAD, porta fixa do preview do Suporte
# VITE_ORION_SUPORTE_URL=http://10.95.91.53:5180

# Portas entre módulos (dev 61xx / prod 51xx — ver `.env.development` e `.env.production`)
# VITE_ORION_SUPORTE_PORT=6180
# VITE_ORION_QUALIDADE_PORT=6182
# VITE_ORION_JURIDICO_PORT=6183
# VITE_ORION_PATRIMONIO_PORT=6184
# VITE_ORION_MULHER_PORT=6185
# VITE_ORION_AGENDA_PORT=6186
# VITE_ORION_OPERACOES_PORT=6187

# Órion Qualidade — em dev, suba o Vite: `npm run start:full:dev` na raiz (porta 6182).
# VITE_ORION_QUALIDADE_URL=http://10.95.91.53:5182

# Órion Jurídico
# VITE_ORION_JURIDICO_URL=http://10.95.91.53:5183

# Órion Patrimônio
# VITE_ORION_PATRIMONIO_URL=http://10.95.91.53:5184

# Órion Mulher
# VITE_ORION_MULHER_URL=http://10.95.91.53:5185

# Órion Agenda
# VITE_ORION_AGENDA_URL=http://10.95.91.53:5186
